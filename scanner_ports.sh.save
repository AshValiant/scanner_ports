#!/bin/bash
# PORTS SCANNER
ip_target=$1

common_ports=( 21 22 25 53 80 443 445 8080 3306 1000 );

scan_ports()  {
     timeout 1 bash -c "echo 'nothing' > /dev/tcp/$1/$2 &> /dev/null
     if [ $? -eq 0 ]; then
        echo "Port $2 open on $1"
    else 
        echo "Port $2 closed on $1" 
    fi
}

if [ $# -eq 1 ]; then 

    for port in ${common_ports[*]} ; do 
        scan_port $ip_target $port 
    done
elif [ $# -eq 3 ]; then 
    for ((port=$2; port<=$3; port++)); do
        scan_port $ip_target $port
    done
else
    echo "Use : scanner_port.sh <IP> [<START PORT> <END PORT>]"
fi
